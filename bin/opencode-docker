#!/usr/bin/env bash
set -euo pipefail

SCRIPT_NAME="$(basename "$0")"
DEFAULT_IMAGE="opencode-docker:latest"
CONTAINER_PROJECT_DIR="/workspace"
CONTAINER_HOME_DIR="/home/opencode"
LA_BRIGUADE_HOST_CONFIG_RELATIVE="la_briguade"
LA_BRIGUADE_LOCAL_MODE_DEFAULT="auto"
LA_BRIGUADE_PLUGIN_ENTRY_RELATIVE="plugins/index.js"
CACHE_CTRL_LOCAL_MODE_DEFAULT="auto"
CACHE_CTRL_HOST_BINARY_ENTRY_RELATIVE=".local/bin/cache-ctrl"
CACHE_CTRL_HOST_SKILL_ENTRY_RELATIVE=".config/opencode/skills/cache-ctrl-caller/SKILL.md"
CACHE_CTRL_CONTAINER_BIN_DIR="/home/opencode/.local/bin"
CACHE_CTRL_CONTAINER_BINARY_PATH="${CACHE_CTRL_CONTAINER_BIN_DIR}/cache-ctrl"

usage() {
  cat <<'EOF'
Usage:
  bin/opencode-docker [--project <host-path>] [--image <image-ref>] [--shell] [--] [command ...args]

Options:
  --project <host-path>  Host project directory to mount (default: current directory)
  --image <image-ref>    Docker image reference (default: opencode-docker:latest)
  --shell                Start an interactive shell inside the container
  -h, --help             Show this help message
EOF
}

fail() {
  local message="$1"
  echo "${SCRIPT_NAME}: ${message}" >&2
  exit 1
}

warn() {
  local message="$1"
  echo "${SCRIPT_NAME}: Warning: ${message}" >&2
}

ensure_dir() {
  local dir_path="$1"

  if [[ -d "${dir_path}" ]]; then
    return 0
  fi

  if mkdir -p "${dir_path}" 2>/dev/null; then
    return 0
  fi

  fail "Unable to create persistence directory: ${dir_path}. Remediation: verify parent directory ownership/permissions or create it manually, then re-run."
}

resolve_path() {
  local input_path="$1"

  if command -v realpath >/dev/null 2>&1; then
    realpath "${input_path}"
    return
  fi

  if command -v python3 >/dev/null 2>&1; then
    python3 -c 'import os,sys; print(os.path.realpath(sys.argv[1]))' "${input_path}"
    return
  fi

  fail "Unable to resolve path '${input_path}'. Install 'realpath' or 'python3'."
}

resolve_symlink_target_absolute() {
  local symlink_path="$1"
  local symlink_dir
  local raw_target

  symlink_dir="$(dirname "${symlink_path}")"
  raw_target="$(readlink "${symlink_path}")"

  if [[ "${raw_target}" == /* ]]; then
    printf '%s\n' "${raw_target}"
    return
  fi

  resolve_path "${symlink_dir}/${raw_target}"
}

validate_local_mode_value() {
  local local_mode="$1"

  case "${local_mode}" in
    auto|force|off)
      return 0
      ;;
    *)
      fail "Invalid LA_BRIGUADE_LOCAL_MODE value '${local_mode}'. Allowed values: auto, force, off."
      ;;
  esac
}

validate_cache_ctrl_local_mode_value() {
  local local_mode="$1"

  case "${local_mode}" in
    auto|force|off)
      return 0
      ;;
    *)
      fail "Invalid CACHE_CTRL_LOCAL_MODE value '${local_mode}'. Allowed values: auto, force, off. Remediation: set CACHE_CTRL_LOCAL_MODE to one of the allowed values or unset it to use default auto mode."
      ;;
  esac
}

derive_cache_ctrl_checkout_root_from_target() {
  local resolved_target_path="$1"
  local source_label="$2"
  local search_dir
  local expected_skill_path

  search_dir="$(resolve_path "$(dirname "${resolved_target_path}")")"

  while true; do
    expected_skill_path="${search_dir}/skills/cache-ctrl-caller/SKILL.md"

    if [[ -d "${search_dir}" && -r "${search_dir}" && -x "${search_dir}" && -f "${expected_skill_path}" && -r "${expected_skill_path}" ]]; then
      printf '%s\n' "${search_dir}"
      return 0
    fi

    if [[ "${search_dir}" == "/" ]]; then
      break
    fi

    search_dir="$(dirname "${search_dir}")"
  done

  printf '%s\n' "Unable to derive cache-ctrl checkout root from ${source_label} '${resolved_target_path}'. Expected an accessible ancestor containing 'skills/cache-ctrl-caller/SKILL.md'. Remediation: point ~/.local/bin/cache-ctrl and ~/.config/opencode/skills/cache-ctrl-caller/SKILL.md to the same local cache-ctrl checkout, or disable local mode with CACHE_CTRL_LOCAL_MODE=off."
  return 1
}

resolve_cache_ctrl_local_state() {
  local local_mode="$1"
  local configured_local_path="$2"
  local host_binary_entry_path="$3"
  local host_skill_entry_path="$4"
  local mode_label="CACHE_CTRL local-dev"
  local resolved_binary_target=""
  local resolved_skill_target=""
  local derived_root_from_binary=""
  local derived_root_from_skill=""
  local authoritative_root=""
  local resolved_configured_local_path=""
  local -a preflight_issues=()

  if [[ "${local_mode}" == "off" ]]; then
    CACHE_CTRL_LOCAL_ACTIVE="false"
    CACHE_CTRL_LOCAL_PROJECT_ROOT=""
    CACHE_CTRL_LOCAL_BINARY_TARGET=""
    return 0
  fi

  if [[ ! -e "${host_binary_entry_path}" && ! -L "${host_binary_entry_path}" ]]; then
    preflight_issues+=("Missing host binary entry '${host_binary_entry_path}'.")
  elif [[ -L "${host_binary_entry_path}" && ! -e "${host_binary_entry_path}" ]]; then
    preflight_issues+=("Host binary entry '${host_binary_entry_path}' is a broken symlink.")
  else
    resolved_binary_target="$(resolve_path "${host_binary_entry_path}")"

    if [[ ! -e "${resolved_binary_target}" ]]; then
      preflight_issues+=("Resolved binary target does not exist: ${resolved_binary_target}.")
    elif [[ ! -f "${resolved_binary_target}" ]]; then
      preflight_issues+=("Resolved binary target is not a file: ${resolved_binary_target}.")
    elif [[ ! -r "${resolved_binary_target}" || ! -x "${resolved_binary_target}" ]]; then
      preflight_issues+=("Resolved binary target is not readable/executable: ${resolved_binary_target}.")
    elif ! derived_root_from_binary="$(derive_cache_ctrl_checkout_root_from_target "${resolved_binary_target}" "resolved binary target")"; then
      preflight_issues+=("${derived_root_from_binary}")
    fi
  fi

  if [[ ! -e "${host_skill_entry_path}" && ! -L "${host_skill_entry_path}" ]]; then
    preflight_issues+=("Missing canonical skill link '${host_skill_entry_path}'.")
  elif [[ ! -L "${host_skill_entry_path}" ]]; then
    preflight_issues+=("Canonical skill entry '${host_skill_entry_path}' must be a symlink in local-dev mode.")
  elif [[ ! -e "${host_skill_entry_path}" ]]; then
    preflight_issues+=("Canonical skill link '${host_skill_entry_path}' is a broken symlink.")
  else
    resolved_skill_target="$(resolve_path "${host_skill_entry_path}")"

    if [[ ! -e "${resolved_skill_target}" ]]; then
      preflight_issues+=("Resolved skill target does not exist: ${resolved_skill_target}.")
    elif [[ ! -f "${resolved_skill_target}" || ! -r "${resolved_skill_target}" ]]; then
      preflight_issues+=("Resolved skill target is not a readable file: ${resolved_skill_target}.")
    elif ! derived_root_from_skill="$(derive_cache_ctrl_checkout_root_from_target "${resolved_skill_target}" "resolved skill target")"; then
      preflight_issues+=("${derived_root_from_skill}")
    fi
  fi

  if [[ -n "${derived_root_from_binary}" && -n "${derived_root_from_skill}" && "${derived_root_from_binary}" != "${derived_root_from_skill}" ]]; then
    preflight_issues+=("Resolved cache-ctrl roots disagree: binary-derived='${derived_root_from_binary}', skill-derived='${derived_root_from_skill}'.")
  fi

  if [[ -n "${derived_root_from_binary}" && -n "${derived_root_from_skill}" ]]; then
    authoritative_root="${derived_root_from_binary}"
  fi

  if [[ -n "${configured_local_path}" && -n "${authoritative_root}" ]]; then
    if [[ ! -d "${configured_local_path}" || ! -r "${configured_local_path}" || ! -x "${configured_local_path}" ]]; then
      preflight_issues+=("CACHE_CTRL_LOCAL_PATH '${configured_local_path}' must be an accessible directory when local mode is active.")
    else
      resolved_configured_local_path="$(resolve_path "${configured_local_path}")"
      if [[ "${resolved_configured_local_path}" != "${authoritative_root}" ]]; then
        preflight_issues+=("CACHE_CTRL_LOCAL_PATH must match the derived cache-ctrl checkout root. Derived='${authoritative_root}', received='${resolved_configured_local_path}'.")
      fi
    fi
  fi

  if [[ "${#preflight_issues[@]}" -gt 0 ]]; then
    if [[ "${local_mode}" == "force" ]]; then
      fail "${mode_label} preflight failed: ${preflight_issues[*]} Remediation: fix the reported local cache-ctrl inputs or disable local mode with CACHE_CTRL_LOCAL_MODE=off."
    fi

    warn "${mode_label} auto mode did not activate. Continuing with image-installed cache-ctrl runtime. Reasons: ${preflight_issues[*]} Remediation: fix local cache-ctrl links, or set CACHE_CTRL_LOCAL_MODE=off to silence this warning."
    CACHE_CTRL_LOCAL_ACTIVE="false"
    CACHE_CTRL_LOCAL_PROJECT_ROOT=""
    CACHE_CTRL_LOCAL_BINARY_TARGET=""
    return 0
  fi

  CACHE_CTRL_LOCAL_ACTIVE="true"
  CACHE_CTRL_LOCAL_PROJECT_ROOT="${authoritative_root}"
  CACHE_CTRL_LOCAL_BINARY_TARGET="${resolved_binary_target}"
  return 0
}

prepare_la_briguade_config_mount() {
  local host_source_path="$1"
  local container_target_path="$2"

  if [[ ! -e "${host_source_path}" && ! -L "${host_source_path}" ]]; then
    return 0
  fi

  if [[ -L "${host_source_path}" && ! -e "${host_source_path}" ]]; then
    warn "Skipping la-briguade config import from ${host_source_path}: path is a broken symlink. Remediation: fix symlink target or remove the path if unused."
    return 0
  fi

  if [[ ! -r "${host_source_path}" ]]; then
    warn "Skipping la-briguade config import from ${host_source_path}: source exists but is not readable. Remediation: grant read permissions or remove the path if unused."
    return 0
  fi

  if [[ -d "${host_source_path}" && ! -x "${host_source_path}" ]]; then
    warn "Skipping la-briguade config import from ${host_source_path}: directory is not traversable. Remediation: add execute permission on the directory."
    return 0
  fi

  docker_run_args+=(--volume "${host_source_path}:${container_target_path}")
}

derive_local_project_root_from_symlink_target() {
  local symlink_target_path="$1"
  local derived_project_root
  local package_manifest_path

  derived_project_root="$(resolve_path "$(dirname "${symlink_target_path}")/..")"
  package_manifest_path="${derived_project_root}/package.json"

  if [[ ! -d "${derived_project_root}" ]]; then
    fail "Unable to derive la-briguade local project root from '${symlink_target_path}'. Expected directory at '<resolved-target>/../..' (resolved to '${derived_project_root}'). Remediation: ensure plugins/index.js points into a local la-briguade layout where '../../' reaches the project root, or disable local mode with LA_BRIGUADE_LOCAL_MODE=off."
  fi

  if [[ ! -r "${derived_project_root}" || ! -x "${derived_project_root}" ]]; then
    fail "Derived la-briguade local project root is not accessible: ${derived_project_root}. Remediation: grant read/execute permissions on the directory, or disable local mode with LA_BRIGUADE_LOCAL_MODE=off."
  fi

  if [[ ! -f "${package_manifest_path}" || ! -r "${package_manifest_path}" ]]; then
    fail "Derived la-briguade local project root is invalid: ${derived_project_root}. Expected a readable package manifest at '${package_manifest_path}' to confirm a project-root mount target. Remediation: ensure plugins/index.js points to a local la-briguade build output where '<resolved-target>/../..' is the project root, or disable local mode with LA_BRIGUADE_LOCAL_MODE=off."
  fi

  printf '%s\n' "${derived_project_root}"
}

resolve_la_briguade_local_project_root() {
  local local_mode="$1"
  local plugin_entry_path="$2"
  local configured_local_path="$3"
  local active_mode=false
  local detected_symlink_target=""
  local detected_project_root=""

  case "${local_mode}" in
    off)
      printf '\n'
      return 0
      ;;
    auto)
      if [[ -L "${plugin_entry_path}" ]]; then
        active_mode=true
      fi
      ;;
    force)
      active_mode=true
      ;;
  esac

  if [[ "${active_mode}" != true ]]; then
    printf '\n'
    return 0
  fi

  if [[ ! -L "${plugin_entry_path}" ]]; then
    fail "LA_BRIGUADE local-link mode requires ${plugin_entry_path} to be a symlink. Remediation: replace ${LA_BRIGUADE_PLUGIN_ENTRY_RELATIVE} with a symlink to your local la-briguade build output."
  fi

  if [[ ! -e "${plugin_entry_path}" ]]; then
    fail "LA_BRIGUADE local-link mode found a broken symlink at ${plugin_entry_path}. Remediation: rebuild la-briguade local output or update ${LA_BRIGUADE_PLUGIN_ENTRY_RELATIVE} to a valid target."
  fi

  detected_symlink_target="$(resolve_symlink_target_absolute "${plugin_entry_path}")"

  if [[ ! -e "${detected_symlink_target}" ]]; then
    fail "Resolved la-briguade symlink target does not exist: ${detected_symlink_target}. Remediation: rebuild la-briguade local output or update ${LA_BRIGUADE_PLUGIN_ENTRY_RELATIVE}."
  fi

  if [[ ! -r "${detected_symlink_target}" ]]; then
    fail "Resolved la-briguade symlink target is not readable: ${detected_symlink_target}. Remediation: fix permissions on the local build target."
  fi

  if [[ -n "${configured_local_path}" ]]; then
    if [[ "${local_mode}" == "force" && ( ! -d "${configured_local_path}" || ! -r "${configured_local_path}" || ! -x "${configured_local_path}" ) ]]; then
      fail "Invalid LA_BRIGUADE_LOCAL_PATH '${configured_local_path}'. In force mode this path must be an accessible directory (exists with read/execute permissions)."
    fi

    if ! detected_project_root="$(derive_local_project_root_from_symlink_target "${detected_symlink_target}")"; then
      return 1
    fi

    if [[ "${configured_local_path}" != "${detected_project_root}" ]]; then
      fail "LA_BRIGUADE_LOCAL_PATH must exactly match the project root derived from the resolved symlink target ('${detected_project_root}', from '${detected_symlink_target}/../..') when local-link mode is active. Received '${configured_local_path}'."
    fi
  else
    if ! detected_project_root="$(derive_local_project_root_from_symlink_target "${detected_symlink_target}")"; then
      return 1
    fi
  fi

  printf '%s\n' "${detected_project_root}"
}

if ! command -v docker >/dev/null 2>&1; then
  fail "Docker CLI is required but was not found in PATH. Install Docker and re-run."
fi

project_path="$(pwd)"
image_ref="${OPENCODE_DOCKER_IMAGE:-${DEFAULT_IMAGE}}"
shell_mode=false
declare -a passthrough_command=()

while [[ "$#" -gt 0 ]]; do
  case "$1" in
    --project)
      [[ "$#" -ge 2 ]] || fail "--project requires a value"
      project_path="$2"
      shift 2
      ;;
    --image)
      [[ "$#" -ge 2 ]] || fail "--image requires a value"
      image_ref="$2"
      shift 2
      ;;
    --shell)
      shell_mode=true
      shift
      ;;
    --)
      shift
      passthrough_command=("$@")
      break
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      passthrough_command=("$@")
      break
      ;;
  esac
done

if [[ ! -d "${project_path}" ]]; then
  fail "Project path does not exist or is not a directory: ${project_path}. Remediation: pass a valid directory with --project."
fi

resolved_project_path="$(resolve_path "${project_path}")"

if [[ ! -d "${resolved_project_path}" ]]; then
  fail "Resolved project path is not a directory: ${resolved_project_path}."
fi

host_config_dir="${HOME}/.config/opencode"
host_state_dir="${HOME}/.local/state/opencode"
host_share_dir="${HOME}/.local/share/opencode"
host_la_briguade_config_dir="${HOME}/${LA_BRIGUADE_HOST_CONFIG_RELATIVE}"
la_briguade_local_mode="${LA_BRIGUADE_LOCAL_MODE:-${LA_BRIGUADE_LOCAL_MODE_DEFAULT}}"
la_briguade_local_path="${LA_BRIGUADE_LOCAL_PATH:-}"
plugin_entry_path="${resolved_project_path}/${LA_BRIGUADE_PLUGIN_ENTRY_RELATIVE}"
cache_ctrl_local_mode="${CACHE_CTRL_LOCAL_MODE:-${CACHE_CTRL_LOCAL_MODE_DEFAULT}}"
cache_ctrl_local_path="${CACHE_CTRL_LOCAL_PATH:-}"
cache_ctrl_host_binary_entry_path="${HOME}/${CACHE_CTRL_HOST_BINARY_ENTRY_RELATIVE}"
cache_ctrl_host_skill_entry_path="${HOME}/${CACHE_CTRL_HOST_SKILL_ENTRY_RELATIVE}"

ensure_dir "${host_config_dir}"
ensure_dir "${host_state_dir}"
ensure_dir "${host_share_dir}"
validate_local_mode_value "${la_briguade_local_mode}"
validate_cache_ctrl_local_mode_value "${cache_ctrl_local_mode}"

if [[ "${shell_mode}" == true ]]; then
  command_to_run=("/bin/bash")
elif [[ "${#passthrough_command[@]}" -eq 0 ]]; then
  command_to_run=("opencode")
else
  command_to_run=("${passthrough_command[@]}")
fi

docker_run_args=(
  --rm
  --workdir "${CONTAINER_PROJECT_DIR}"
  --env "HOST_UID=$(id -u)"
  --env "HOST_GID=$(id -g)"
  --volume "${resolved_project_path}:${CONTAINER_PROJECT_DIR}"
  --volume "${host_config_dir}:/home/opencode/.config/opencode"
  --volume "${host_state_dir}:/home/opencode/.local/state/opencode"
  --volume "${host_share_dir}:${CONTAINER_HOME_DIR}/.local/share/opencode"
)

prepare_la_briguade_config_mount "${host_la_briguade_config_dir}" "${CONTAINER_HOME_DIR}/${LA_BRIGUADE_HOST_CONFIG_RELATIVE}"

if ! la_briguade_local_project_root="$(resolve_la_briguade_local_project_root "${la_briguade_local_mode}" "${plugin_entry_path}" "${la_briguade_local_path}")"; then
  exit 1
fi
if [[ -n "${la_briguade_local_project_root}" ]]; then
  docker_run_args+=(--volume "${la_briguade_local_project_root}:${la_briguade_local_project_root}")
fi

CACHE_CTRL_LOCAL_ACTIVE="false"
CACHE_CTRL_LOCAL_PROJECT_ROOT=""
CACHE_CTRL_LOCAL_BINARY_TARGET=""
resolve_cache_ctrl_local_state "${cache_ctrl_local_mode}" "${cache_ctrl_local_path}" "${cache_ctrl_host_binary_entry_path}" "${cache_ctrl_host_skill_entry_path}"

if [[ "${CACHE_CTRL_LOCAL_ACTIVE}" == "true" ]]; then
  docker_run_args+=(--volume "${CACHE_CTRL_LOCAL_PROJECT_ROOT}:${CACHE_CTRL_LOCAL_PROJECT_ROOT}")
  docker_run_args+=(--env "OPENCODE_CACHE_CTRL_LOCAL_TARGET=${CACHE_CTRL_LOCAL_BINARY_TARGET}")
  docker_run_args+=(--env "OPENCODE_PREPEND_PATH=${CACHE_CTRL_CONTAINER_BIN_DIR}")
fi

if [[ "${shell_mode}" == true || ( -t 0 && -t 1 ) ]]; then
  docker_run_args+=(--interactive --tty)
fi

exec docker run "${docker_run_args[@]}" "${image_ref}" "${command_to_run[@]}"
