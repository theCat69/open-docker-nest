{
  "name": "open-docker-nest",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "open-docker-nest": "bin/open-docker-nest.js"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "files": [
    "bin/",
    "src/",
    "docker/",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "bunx tsc --noEmit",
    "test": "bunx vitest run",
    "test:watch": "bunx vitest",
    "test:e2e": "bunx vitest -c ./e2e/vitest.config.ts run",
    "schema:generate": "bun run src/config/generate-schema.ts",
    "typecheck": "bunx tsc --noEmit",
    "prepublishOnly": "bun run typecheck && bun run test && bun run test:e2e"
  },
  "devDependencies": {
    "@types/bun": "^1.3.12",
    "vitest": "^4.1.4"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "zod": "^4.3.6"
  }
}
