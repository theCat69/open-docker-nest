{
  "name": "dock-opencode",
  "version": "0.1.0",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "bin": {
    "opencode-docker": "bin/opencode-docker.js"
  },
  "scripts": {
    "build": "bunx tsc --noEmit",
    "test": "bunx vitest run",
    "test:watch": "bunx vitest",
    "test:e2e": "bunx vitest -c ./e2e/vitest.config.ts run",
    "typecheck": "bunx tsc --noEmit",
    "prepublishOnly": "bun run typecheck && bun run test && bun run test:e2e"
  },
  "devDependencies": {
    "@types/bun": "^1.3.12",
    "vitest": "^4.1.4"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "zod": "^4.3.6"
  }
}
