{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "extraContainerEnvironment": {
      "default": {},
      "type": "object",
      "propertyNames": {
        "type": "string",
        "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
      },
      "additionalProperties": {
        "anyOf": [
          {
            "type": "string",
            "pattern": "^(?:(?!\\{env:)[\\s\\S])*$"
          },
          {
            "type": "string",
            "pattern": "^\\{env:([A-Z_][A-Z0-9_]*)\\}$"
          }
        ]
      }
    }
  },
  "additionalProperties": false
}
